import { build, context } from "esbuild";

const watch = process.argv.includes("--watch");

const options = {
  entryPoints: ["src/mcp-server.ts"],
  outfile: "dist/mcp-server.js",
  bundle: true,
  platform: "node",
  target: "node22",
  format: "esm",
  sourcemap: true,
  banner: { js: "#!/usr/bin/env node" },
  // Bundle everything — MCP plugins ship a single self-contained file.
  external: [],
};

if (watch) {
  const ctx = await context(options);
  await ctx.watch();
  process.stderr.write("[{{NAME}}] bundler watching...\n");
} else {
  await build(options);
  process.stderr.write("[{{NAME}}] build complete\n");
}
