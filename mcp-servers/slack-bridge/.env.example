# Slack Bridge MCP — Environment Variables
# Copy this file to .env and fill in your tokens.
# These are loaded via the shell or your .mcp.json config.

# Required: Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Required: App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=xapp-your-app-token

# Mode: "poll" (default) or "reactive"
SLACK_BRIDGE_MODE=reactive

# Reactive mode: auto-reply to Slack messages
SLACK_BRIDGE_AUTO_REPLY=true

# Reactive mode: max tokens for Claude's response
SLACK_BRIDGE_MAX_TOKENS=1024

# Optional: comma-separated channel IDs to monitor (empty = all)
SLACK_CHANNELS=

# Optional: only capture thread replies, not top-level messages
SLACK_THREAD_ONLY=false
