        "SLACK_BRIDGE_AUTO_REPLY": "true",
        "SLACK_BRIDGE_MAX_TOKENS": "1024",
        "SLACK_CHANNELS": "",
        "SLACK_DM_USERS": "U02M1QFA0AF",
        "SLACK_THREAD_ONLY": "false"
      }
    }
