  "mcpServers": {
    "memory": {
      "command": "node",
      "args": [
        "mcp-servers/memory/dist/index.js"
      ],
      "env": {
        "MEMORY_FILE_PATH": ".claude/memory.jsonl"
      }
    },
    "conventions": {
      "command": "node",
      "args": [
        "mcp-servers/conventions/dist/index.js"
      ]
    },
    "slack-bridge": {
      "command": "node",
      "args": [
        "mcp-servers/slack-bridge/dist/index.js"
      ],
