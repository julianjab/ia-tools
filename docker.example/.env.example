# docker.example/.env — copy to .env and fill in.
#
# Two categories of variable live here:
#
#   1) Secrets the pod needs at runtime (auth tokens). Anything that
#      should NOT live in a versioned yaml file.
#   2) Placeholders that team-workflow.yaml references via `${VAR}`.
#      The loader (`load-tw-config.sh`) substitutes them at boot.
#
# .gitignored — never commit your filled-in copy.

# ─── 1. Secrets ─────────────────────────────────────────────────────────────
# Claude auth (one of these is required):
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# GitHub (required for /pr to open PRs):
GITHUB_TOKEN=

# Slack transport (optional — omit both to run terminal-only):
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ─── 2. team-workflow.yaml placeholders ─────────────────────────────────────
# These names appear as ${VAR} inside team-workflow.example.yaml. Tweak
# the values to wire the pod to the right agent / repos / channels.

# Which consumer agent runs in this pod. Must match a file at
# /root/.claude/agents/<name>.md (baked when extending the base image)
# or be otherwise resolvable. Leave empty for the generic flow.
IA_TW_AGENT_NAME=

# Repos this pod is allowed to touch (whitelist; cloned lazily on first use).
REPO_URL_PRIMARY=https://github.com/your-org/your-primary-repo.git
REPO_URL_SECONDARY=https://github.com/your-org/your-secondary-repo.git

# Slack identifiers for the topic subscriptions + ACL.
SLACK_CHANNEL_PRIMARY=
SLACK_OPERATOR=
SLACK_TEAM_MEMBER_A=

# State root inside the container (PVC mount point in k8s).
IA_TW_STATE_ROOT=/state

# Git identity for commits opened by /pr.
GIT_AUTHOR_NAME=team-workflow-bot
GIT_AUTHOR_EMAIL=team-workflow-bot@users.noreply.github.com
