# docker.example — copy to .env and fill in. Never commit the real .env.
#
# Env vars ARE the pod's configuration contract (12-factor / k8s ConfigMap).
# pod-config.json is an optional readable mirror — env always wins.

# --- Claude auth (one of these is required) ----------------------------------
# Preferred: a long-lived OAuth token minted for this bot.
CLAUDE_CODE_OAUTH_TOKEN=
# Or a plain API key.
# ANTHROPIC_API_KEY=

# --- Pod dispatch profile ----------------------------------------------------
# This is what makes team-workflow non-static: the router reads these at boot
# and forwards them to every orchestrator sub-session it spawns.
#
#   Dev-host profile  → leave all three unset (defaults: lead + worktree-local).
#   Pod profile       → the values below: one repo, clone-work-PR.
IA_TW_DISPATCH_AGENT=team-workflow:repo-worker
IA_TW_DISPATCH_PROVISION=clone

# The repo this pod owns. Required when IA_TW_DISPATCH_PROVISION=clone.
# Every repo-worker the router dispatches clones THIS url. Use an https url
# with an embedded token, or mount an ssh key and use the ssh form.
IA_TW_REPO_URL=https://x-access-token:${GITHUB_TOKEN}@github.com/your-org/your-frontend-repo.git

# --- GitHub (required for /pr to open PRs) -----------------------------------
GITHUB_TOKEN=

# --- git identity for repo-worker commits ------------------------------------
GIT_AUTHOR_NAME=team-workflow-bot
GIT_AUTHOR_EMAIL=team-workflow-bot@users.noreply.github.com

# --- Slack transport (optional) ----------------------------------------------
# Set both to give the router a Slack channel. Omit to run terminal-only.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Optional: auto-subscribe the router to a topic at boot.
#   DM:<user_id>                  — DMs with a user
#   <channel_id>                  — a whole channel
#   <channel_id>:*:<thread_ts>    — a single thread
# SLACK_TOPICS=

# --- persistent state --------------------------------------------------------
# Where state.md + repo clones live. In k8s, mount a PVC here.
IA_TW_STATE_ROOT=/state

# --- optional: path to the openclaw-style profile file -----------------------
# Defaults to /opt/ia-tools/pod-config.json (baked into the image). Override
# to mount your own. Delete the file / point elsewhere to use env vars only.
# POD_CONFIG=/opt/ia-tools/pod-config.json
