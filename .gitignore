# Dependencies
node_modules/
.pnpm-store/

# Build
dist/
# Exception: the slack-bridge plugin ships its built output so consumers
# installing the Claude plugin don't need a build step. Staleness is enforced
# by scripts/check-slack-bridge-dist.sh (run as prebuild + CI check).
!plugins/slack-bridge/dist/
*.tsbuildinfo
*.log
.logs/
.turbo/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp
.history/

# OS
.DS_Store
Thumbs.db

# Git worktrees (parallel development)
.worktrees/

# Local data / caches
.data/
.cache/

# Slack Bridge local config (contains channel/subscription preferences; never commit)
# Schema documented in .claude/.channels.json.example
.claude/.channels.json

# Per-task coordination state (ephemeral, same category as .worktrees/)
.claude/teams/

# Agent memory written by team-workflow agents (per-user, per-project state)
.claude/agent-memory/

# Legacy / archived agents (kept locally, not tracked)
agents_bck/

# SDLC tooling local state
.sdlc/
